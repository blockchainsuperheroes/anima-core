---
const links = {
  standard: [
    { label: 'Ethereum ERC Index', href: 'https://eips.ethereum.org/erc' },
    { label: 'ERC Draft (PR #1559)', href: 'https://github.com/ethereum/ERCs/pull/1559' },
    { label: 'Ethereum Magicians', href: 'https://ethereum-magicians.org/' },
    { label: 'GitHub Repository', href: 'https://github.com/blockchainsuperheroes/Pentagon-AI' },
    { label: 'ANIMA Demo', href: 'https://blockchainsuperheroes.github.io/anima-demo/' },
  ],
  ecosystem: [
    { label: 'Pentagon Games', href: 'https://pentagon.games' },
    { label: 'AgentCert.io', href: 'https://agentcert.io' },
    { label: 'ERC-721 (erc721.org)', href: 'https://erc721.org' },
    { label: 'Tokenbound', href: 'https://tokenbound.org' },
    { label: 'ERC-4626 Alliance', href: 'https://erc4626.info' },
    { label: 'ERC-4337 Docs', href: 'https://www.erc4337.io/docs' },
  ],
  site: [
    { label: 'What is ERC-8170', href: '/what-is-erc8170' },
    { label: 'Documentation', href: '/docs' },
    { label: 'Registry', href: '/registry' },
    { label: 'Standards', href: '/standards' },
    { label: 'Builders', href: '/builders' },
    { label: 'FAQ', href: '/faq' },
  ],
};
---
<footer class="border-t border-white/5 mt-24">
  <div class="container-narrow py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <span class="text-xl font-bold text-white">ERC-8170</span>
        <p class="mt-3 text-sm text-gray-500 leading-relaxed">
          An on-chain identity standard for AI agents. Part of the Ethereum ERC ecosystem.
        </p>
        <p class="mt-4 text-xs text-gray-600">
          The canonical spec lives on <a href="https://eips.ethereum.org/erc" class="text-accent hover:underline">Ethereum EIPs</a>. 
          This site is the ecosystem hub.
        </p>
      </div>

      <!-- Canonical Links -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Standard</h4>
        <ul class="space-y-2">
          {links.standard.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener" class="text-sm text-gray-500 hover:text-accent transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Ecosystem -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Ecosystem</h4>
        <ul class="space-y-2">
          {links.ecosystem.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener" class="text-sm text-gray-500 hover:text-accent transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Site -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Site</h4>
        <ul class="space-y-2">
          {links.site.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 hover:text-accent transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-600">
        Proposed by <a href="https://pentagon.games" class="text-accent hover:underline">Pentagon Games</a> · 
        Authors: <a href="https://github.com/nftprof" class="text-accent hover:underline">Idon Liu</a>, Pentagon Chain
      </p>
      <p class="text-xs text-gray-600">
        Ecosystem hub · Canonical spec at <a href="https://eips.ethereum.org/erc" class="text-accent hover:underline">Ethereum EIPs</a>
      </p>
    </div>
  </div>
</footer>
