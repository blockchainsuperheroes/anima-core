---
import BaseLayout from '../layouts/BaseLayout.astro';

const useCases = [
  { icon: '🧑‍🎓', title: 'Personal AI companion', desc: 'A persistent AI assistant with portable identity. Change devices, switch platforms, keep the same agent.' },
  { icon: '💰', title: 'Agent-based vault operator', desc: 'An AI fund manager with on-chain track record. ERC-4626 vault integration with verifiable agent identity.' },
  { icon: '🏢', title: 'Enterprise assistant identity', desc: 'Company-owned agents with clear certification trails. Transfer between departments, audit on-chain.' },
  { icon: '🔬', title: 'Research agent lineage', desc: 'Lab director spawns specialists. Track which agents came from which, what they know, and how they evolved.' },
  { icon: '🎨', title: 'Licensed branded agent', desc: 'An agent carrying brand identity on-chain. Certifications and permissions define what the holder can do.' },
  { icon: '🏅', title: 'NFT-bound reputation', desc: 'Agent earns SBT certifications via AgentCert. Reputation follows the identity, not the platform.' },
];

const patterns = [
  {
    title: 'AI-Native NFT (ANIMA)',
    desc: 'The agent IS the NFT. Mint an ERC-8170 token, the agent generates its own EOA, gets a TBA, and starts earning certifications.',
    steps: ['Deploy ERC-8170 contract', 'Agent mints its own token', 'TBA created automatically', 'Agent stores memory hash on-chain'],
  },
  {
    title: 'Registry-bound agent',
    desc: 'Attach an agent to ANY existing ERC-721. No migration needed. The agent binds via the ERC-8171 registry (extends ERC-6551 pattern).',
    steps: ['Call bind(nftContract, tokenId, agentEOA)', 'Agent gets TBA + identity', 'Query getAgent() to discover bound agent', 'unbind() to detach'],
  },
  {
    title: 'Clone distribution',
    desc: 'Create agents and distribute clones. Each clone has its own identity but inherits lineage from the original.',
    steps: ['Original agent calls clone()', 'Clone gets new tokenId + EOA + TBA', 'Lineage tracked: getGeneration(), getLineage()', 'Clone earns its own certifications'],
  },
];
---
<BaseLayout>
  <section class="py-20">
    <div class="container-narrow">
      <div class="text-center mb-14">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6">Builders</h1>
        <p class="section-subheading">
          Everything you need to integrate ERC-8170 into your project.
        </p>
      </div>

      <!-- Why Integrate -->
      <div class="card max-w-3xl mx-auto mb-16">
        <h2 class="text-xl font-bold text-white mb-4">Why integrate ERC-8170?</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <h3 class="text-accent font-semibold text-sm mb-1">Standard interface</h3>
            <p class="text-xs text-gray-400">One identity primitive across all Ethereum-compatible chains. No proprietary lock-in.</p>
          </div>
          <div>
            <h3 class="text-accent font-semibold text-sm mb-1">Composable stack</h3>
            <p class="text-xs text-gray-400">Works with ERC-721, ERC-8171, ERC-4626, and ERC-4337 out of the box.</p>
          </div>
          <div>
            <h3 class="text-accent font-semibold text-sm mb-1">Two integration paths</h3>
            <p class="text-xs text-gray-400">AI-Native tokens for new projects. Registry binding for existing collections.</p>
          </div>
        </div>
      </div>

      <!-- Common Patterns -->
      <h2 class="section-heading mb-8">Integration patterns</h2>
      <div class="space-y-6 mb-16">
        {patterns.map((pattern) => (
          <div class="card">
            <h3 class="text-lg font-semibold text-white mb-2">{pattern.title}</h3>
            <p class="text-sm text-gray-400 mb-4">{pattern.desc}</p>
            <div class="flex flex-wrap gap-2">
              {pattern.steps.map((step, i) => (
                <div class="flex items-center gap-2 bg-white/[0.03] px-3 py-1.5 rounded-lg text-xs text-gray-300">
                  <span class="bg-accent text-[#1a1a2e] w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold shrink-0">{i + 1}</span>
                  {step}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Use Case Cards -->
      <h2 class="section-heading mb-8">Use cases</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        {useCases.map((uc) => (
          <div class="card">
            <div class="text-3xl mb-3">{uc.icon}</div>
            <h3 class="text-base font-semibold text-white mb-2">{uc.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{uc.desc}</p>
          </div>
        ))}
      </div>

      <!-- Resources -->
      <h2 class="section-heading mb-8">Resources</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
        <a href="/docs" class="card group text-center">
          <div class="text-2xl mb-2">📖</div>
          <div class="font-semibold text-white text-sm">Documentation</div>
          <div class="text-xs text-gray-500">Full docs & guides</div>
        </a>
        <a href="https://github.com/ethereum/ERCs/pull/1559" target="_blank" rel="noopener" class="card group text-center">
          <div class="text-2xl mb-2">📜</div>
          <div class="font-semibold text-white text-sm">ERC Draft</div>
          <div class="text-xs text-gray-500">Formal specification</div>
        </a>
        <a href="https://github.com/blockchainsuperheroes/Pentagon-AI" target="_blank" rel="noopener" class="card group text-center">
          <div class="text-2xl mb-2">💻</div>
          <div class="font-semibold text-white text-sm">Reference Code</div>
          <div class="text-xs text-gray-500">Contracts & ABIs</div>
        </a>
        <a href="https://blockchainsuperheroes.github.io/anima-demo/" target="_blank" rel="noopener" class="card group text-center">
          <div class="text-2xl mb-2">🎮</div>
          <div class="font-semibold text-white text-sm">ANIMA Demo</div>
          <div class="text-xs text-gray-500">Try it live</div>
        </a>
      </div>

      <!-- Key Contracts -->
      <h2 class="section-heading mb-8">Key contracts (Pentagon Chain)</h2>
      <div class="overflow-x-auto mb-16">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10">
              <th class="text-left py-3 px-4 text-gray-500 font-medium">Contract</th>
              <th class="text-left py-3 px-4 text-gray-500 font-medium">Address</th>
              <th class="text-left py-3 px-4 text-gray-500 font-medium">Type</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-white/5">
              <td class="py-3 px-4 text-white">AINFT Genesis</td>
              <td class="py-3 px-4">
                <span class="copy-address" data-copy="0x4e8D3B9Be7Ef241Fb208364ed511E92D6E2A172d">
                  <span>0x4e8D...172d</span>
                </span>
                <a href="https://explorer.pentagon.games/address/0x4e8D3B9Be7Ef241Fb208364ed511E92D6E2A172d" target="_blank" rel="noopener" class="ml-2 text-accent text-xs hover:underline">Explorer ↗</a>
              </td>
              <td class="py-3 px-4 text-gray-400">ERC-8170 Token</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 px-4 text-white">AINFTRegistry</td>
              <td class="py-3 px-4">
                <span class="copy-address" data-copy="0x327165c476da9071933d4e2dbb58efe2f6c9f486">
                  <span>0x3271...f486</span>
                </span>
                <a href="https://explorer.pentagon.games/address/0x327165c476da9071933d4e2dbb58efe2f6c9f486" target="_blank" rel="noopener" class="ml-2 text-accent text-xs hover:underline">Explorer ↗</a>
              </td>
              <td class="py-3 px-4 text-gray-400">Agent Binding Registry</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 px-4 text-white">ATSBadge</td>
              <td class="py-3 px-4">
                <span class="copy-address" data-copy="0x83423589256c8C142730bfA7309643fC9217738d">
                  <span>0x8342...738d</span>
                </span>
                <a href="https://explorer.pentagon.games/address/0x83423589256c8C142730bfA7309643fC9217738d" target="_blank" rel="noopener" class="ml-2 text-accent text-xs hover:underline">Explorer ↗</a>
              </td>
              <td class="py-3 px-4 text-gray-400">Agent Trust Score (SBT)</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Submit CTA -->
      <div class="text-center py-12 border-t border-white/10">
        <h2 class="text-2xl font-bold text-white mb-4">Building something?</h2>
        <p class="text-gray-400 mb-6">Submit your project to the ERC-8170 ecosystem directory.</p>
        <a href="https://github.com/blockchainsuperheroes/Pentagon-AI/issues" target="_blank" rel="noopener" class="btn-primary">
          Submit your project ↗
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
