---
import BaseLayout from '../layouts/BaseLayout.astro';
import standards from '../data/standards.json';

const categories = {
  foundation: { label: 'Core Identity Stack', desc: 'The standards that define agent identity, binding, and verification.' },
  companion: { label: 'Companion Standards', desc: 'Optional standards that extend what agents can do with their identity.' },
  related: { label: 'Related Standards', desc: 'Established standards that ERC-8170 acknowledges and builds upon.' },
  composable: { label: 'What Sovereign Agents Unlock', desc: 'Once an agent has identity, these standards define what it can do in the wider ecosystem.' },
};

const statusColors = {
  final: 'bg-green-900/30 text-green-400',
  proposed: 'bg-yellow-900/30 text-yellow-400',
  draft: 'bg-orange-900/30 text-orange-400',
  active: 'bg-blue-900/30 text-blue-400',
};
---
<BaseLayout title="Related Standards — ERC-8170" description="How ERC-8170 composes with ERC-721, ERC-6551, ERC-4626, ERC-4337, and proposed extensions.">
  <div class="container-narrow py-16">
    <div class="text-center mb-16">
      <h1 class="section-heading">Related Standards</h1>
      <p class="section-subheading">
        ERC-8170 is designed to compose with existing Ethereum standards, not replace them. 
        Here's how each standard fits into the agent identity stack.
      </p>
    </div>

    {Object.entries(categories).map(([cat, meta]) => {
      const items = standards.filter(s => s.category === cat);
      if (items.length === 0) return null;
      return (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-white mb-2">{meta.label}</h2>
          <p class="text-gray-500 mb-8">{meta.desc}</p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {items.map((std) => (
              <div class="card">
                <div class="flex items-start justify-between mb-3">
                  <div>
                    <h3 class="text-xl font-bold text-white">{std.name}</h3>
                    <p class="text-sm text-accent">{std.title}</p>
                  </div>
                  <span class={`text-xs px-2 py-0.5 rounded shrink-0 ${statusColors[std.status] || 'bg-gray-900/30 text-gray-400'}`}>
                    {std.status}
                  </span>
                </div>
                
                <p class="text-sm text-gray-400 mb-4 leading-relaxed">{std.description}</p>
                
                <div class="bg-white/[0.03] rounded-lg p-3 mb-4">
                  <p class="text-xs text-gray-500 mb-1">Relation to ERC-8170</p>
                  <p class="text-sm text-gray-300">{std.relevance}</p>
                </div>
                
                <div class="flex gap-3">
                  {std.specUrl && (
                    <a href={std.specUrl} target="_blank" rel="noopener" class="text-xs text-accent hover:underline">
                      Spec ↗
                    </a>
                  )}
                  {std.ecosystemUrl && (
                    <a href={std.ecosystemUrl} target="_blank" rel="noopener" class="text-xs text-accent hover:underline">
                      Ecosystem ↗
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
